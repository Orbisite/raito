# Optionnel : sans ces variables, le site utilise les défauts dans src/config/remoteData.js
# (branche main de Orbisite/raito-api).

# VITE_CONTENT_URL=https://raw.githubusercontent.com/ORG/raito-api/main/content.json
# VITE_THEME_URL=https://raw.githubusercontent.com/ORG/raito-api/main/theme.json
# VITE_SITE_URL=https://raw.githubusercontent.com/ORG/raito-api/main/site.json
# VITE_API_IMG_BASE=https://raw.githubusercontent.com/ORG/raito-api/main/img

# Développement local : servir le dossier du dépôt API (pas orbisite/api sauf copie identique).
# npx serve /chemin/vers/raito-api -l 8787
# VITE_CONTENT_URL=http://127.0.0.1:8787/content.json
# VITE_THEME_URL=http://127.0.0.1:8787/theme.json
# VITE_SITE_URL=http://127.0.0.1:8787/site.json
# VITE_API_IMG_BASE=http://127.0.0.1:8787/img
